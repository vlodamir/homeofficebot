{
  "name": "homeofficebot",
  "version": "1.0.0",
  "private": true,
  "description": "Slack bot for daily home office voting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js",
    "dev": "tsx src/index.ts -- --config config.yaml",
    "send-now": "tsx src/sendNow.ts -- --config config.yaml",
    "start": "node dist/index.js -- --config config.yaml",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@slack/bolt": "^4.5.0",
    "node-cron": "^4.2.1",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}